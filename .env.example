# =============================================================================
# Tailor-App Backend — Environment Configuration
# -----------------------------------------------------------------------------
# Copy this file to `.env` and fill in the values below.
# DO NOT commit `.env` to version control. DO NOT ship `.env` in any package.
# =============================================================================

# --- Server ------------------------------------------------------------------
PORT=5000
NODE_ENV=development

# --- Database ----------------------------------------------------------------
# Local example: mongodb://localhost:27017/tailor_db
# Atlas example: mongodb+srv://<user>:<pass>@cluster0.mongodb.net/tailor_db
MONGO_URI=

# --- Auth --------------------------------------------------------------------
# REQUIRED. Generate a long random string (e.g. `openssl rand -hex 48`).
# The app will refuse to issue tokens if this is left blank in production.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Default Admin (seeded on first boot) ------------------------------------
# REQUIRED in production. If both are blank, the server logs an error and does
# not seed an admin user. In development, a throw-away default is used.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# --- Frontend URL (for CORS + outbound tracking links) -----------------------
# Single origin or comma-separated list. Do NOT use `*` in production.
# Examples:
#   FRONTEND_URL=http://localhost:5173
#   FRONTEND_URL=https://app.example.com,https://admin.example.com
FRONTEND_URL=http://localhost:5173

# --- Cloudinary (OPTIONAL — image uploads) -----------------------------------
# Leave blank to disable image uploads. When unset, upload endpoints return
# a clear error instead of crashing.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Twilio (OPTIONAL — WhatsApp / SMS customer notifications) --------------
# Leave blank to disable notifications. The app still creates orders and
# returns the tracking link for manual sharing.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
