PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/tailor_db

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Twilio (for WhatsApp/SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# Default country code applied to 10-digit phone numbers without a leading code (digits only)
DEFAULT_COUNTRY_CODE=91

# SMTP (for agent / tenant credential emails). Leave placeholders to skip email delivery.
# Examples: Gmail SMTP (smtp.gmail.com:587), SendGrid (smtp.sendgrid.net:587), Mailgun, etc.
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM="Tailor Tracker <no-reply@yourdomain.com>"

# App
FRONTEND_URL=http://localhost:5173
# Shop name shown at the bottom of WhatsApp/SMS order messages
SHOP_NAME=Clorrr Tailors
ADMIN_EMAIL=admin@tailorshop.com
ADMIN_PASSWORD=Admin@123
